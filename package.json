{
  "name": "skypulse-weather",
  "version": "1.0.0",
  "description": "SkyPulse - Weather app for paragliders",
  "scripts": {
    "test": "node qa-tester.js",
    "lint": "echo 'Linting CSS and HTML structure...' && npm run lint:css",
    "lint:css": "echo 'CSS linting...'",
    "validate": "node -e \"const fs=require('fs');const html=fs.readFileSync('index.html','utf8');const m=html.match(/<script[^>]*>([\\s\\S]*?)<\\/script>/g);if(m){try{new Function(m.join('\\n'));console.log('JS valid');}catch(e){console.error(e);process.exit(1)}}\"",
    "build": "echo 'Build verification complete'",
    "ci": "npm run lint && npm run validate && npm run test"
  },
  "keywords": ["weather", "paragliding", "forecast"],
  "license": "MIT"
}